@page "/facturas"
@using VeterinariaAntioquia.Shared.Models
@using VeterinariaAntioquia.Shared.Services
@inject FacturaService FacturaService
@inject NavigationManager Navigation
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "administrador")]

<PageTitle>Facturación — VetAntioquia</PageTitle>

<div class="fac-wrap">
    <div class="fac-header">
        <h1 class="fac-title">
            <i class="fa-solid fa-file-invoice-dollar"></i> Facturas
        </h1>
        <p class="fac-sub">Gestión de cobros y facturación</p>
    </div>

    @if (!string.IsNullOrEmpty(errorGlobal))
    {
        <div class="fac-error"><i class="fa-solid fa-circle-exclamation"></i> @errorGlobal</div>
    }

    @if (cargando)
    {
        <div class="fac-loading"><span class="fac-spinner"></span> Cargando módulo...</div>
    }
    else
    {
        <div class="fac-actions">
            <div class="fac-search">
                <i class="fa-solid fa-magnifying-glass"></i>
                <input type="text" placeholder="Buscar por ID de cita o factura..." @bind="busqueda" @bind:event="oninput" />
                @if (!string.IsNullOrEmpty(busqueda))
                {
                    <button class="fac-search-clear" @onclick='() => busqueda = ""'><i class="fa-solid fa-xmark"></i></button>
                }
            </div>
            
            <button class="fac-btn-primary" @onclick="AbrirModalGenerar">
                <i class="fa-solid fa-plus"></i> Generar Factura
            </button>
        </div>

        <div class="fac-table-card">
            <div class="table-responsive">
                <table class="fac-table">
                    <thead>
                        <tr>
                            <th># Factura</th>
                            <th>Cita ID</th>
                            <th>Total</th>
                            <th>Estado</th>
                            <th>Fecha Emisión</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @* Aquí normalmente iteraríamos sobre una lista obtenida de un endpoint GET /api/facturas 
                           Pero para simplificar (ya que el TC solo pide generar y pagar), 
                           el modal permitirá interactuar por ID. *@
                        <tr>
                            <td colspan="6" style="text-align:center; padding: 2rem;">
                                <i>Utiliza el botón superior para generar una factura o el buscador para pagarla.</i>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@* ── Modal Generar Factura ── *@
@if (mostrarModalGenerar)
{
    <div class="fac-modal-backdrop" @onclick="CerrarModalGenerar"></div>
    <div class="fac-modal">
        <div class="fac-modal-header">
            <h3>Generar Factura</h3>
            <button class="fac-close" @onclick="CerrarModalGenerar"><i class="fa-solid fa-xmark"></i></button>
        </div>
        <div class="fac-modal-body">
            <div class="fac-form-group">
                <label>ID de la Cita Completada</label>
                <input type="number" @bind="idCitaFacturar" class="fac-input" placeholder="Ej: 15" />
            </div>
            @if (!string.IsNullOrEmpty(modalError))
            {
                <div class="fac-error-sm">@modalError</div>
            }
        </div>
        <div class="fac-modal-footer">
            <button class="fac-btn-secondary" @onclick="CerrarModalGenerar">Cancelar</button>
            <button class="fac-btn-primary" @onclick="GenerarFactura" disabled="@guardando">
                @(guardando ? "Generando..." : "Generar Factura")
            </button>
        </div>
    </div>
}

@* ── Modal Pagar Factura ── *@
@if (mostrarModalPagar)
{
    <div class="fac-modal-backdrop" @onclick="CerrarModalPagar"></div>
    <div class="fac-modal">
        <div class="fac-modal-header">
            <h3>Pagar Factura #@facturaReciente?.Id</h3>
            <button class="fac-close" @onclick="CerrarModalPagar"><i class="fa-solid fa-xmark"></i></button>
        </div>
        <div class="fac-modal-body">
            <div class="fac-resumen">
                <div class="fac-resumen-item"><span>Subtotal:</span> $ @facturaReciente?.Subtotal.ToString("N2")</div>
                <div class="fac-resumen-item"><span>Impuestos:</span> $ @facturaReciente?.Impuestos.ToString("N2")</div>
                <div class="fac-resumen-item total"><span>Total a Pagar:</span> $ @facturaReciente?.Total.ToString("N2")</div>
            </div>

            <div class="fac-form-group mt-3">
                <label>Método de Pago</label>
                <select @bind="metodoPago" class="fac-input">
                    <option value="">Seleccione...</option>
                    <option value="efectivo">Efectivo</option>
                    <option value="tarjeta">Tarjeta de Crédito / Débito</option>
                    <option value="transferencia">Transferencia</option>
                </select>
            </div>
            @if (!string.IsNullOrEmpty(modalError))
            {
                <div class="fac-error-sm">@modalError</div>
            }
            @if (!string.IsNullOrEmpty(modalSuccess))
            {
                <div class="fac-success-sm">@modalSuccess</div>
            }
        </div>
        <div class="fac-modal-footer">
            <button class="fac-btn-secondary" @onclick="CerrarModalPagar">Cerrar</button>
            <button class="fac-btn-success" @onclick="PagarFactura" disabled="@(guardando || facturaReciente?.Estado == "pagada")">
                <i class="fa-solid fa-money-bill-wave"></i> @(guardando ? "Procesando..." : "Registrar Pago")
            </button>
        </div>
    </div>
}

@code {
    private bool cargando = false;
    private string? errorGlobal { get; set; }
    private string busqueda = "";

    // Modales
    private bool mostrarModalGenerar = false;
    private bool mostrarModalPagar = false;
    private bool guardando = false;
    private string? modalError;
    private string? modalSuccess;

    // Campos Generar
    private int idCitaFacturar;
    private Factura? facturaReciente;

    // Campos Pagar
    private string metodoPago = "";

    protected override void OnInitialized()
    {
        // En una app real aquí cargaríamos la lista de facturas
    }

    private void AbrirModalGenerar()
    {
        idCitaFacturar = 0;
        modalError = null;
        mostrarModalGenerar = true;
    }

    private void CerrarModalGenerar() => mostrarModalGenerar = false;

    private void CerrarModalPagar() => mostrarModalPagar = false;

    private async Task GenerarFactura()
    {
        if (idCitaFacturar <= 0)
        {
            modalError = "Ingresa un ID de cita válido.";
            return;
        }

        modalError = null;
        guardando = true;

        var (factura, err) = await FacturaService.GenerarFacturaAsync(new GenerarFacturaRequest { IdCita = idCitaFacturar });
        
        guardando = false;

        if (err != null)
        {
            modalError = err;
            return;
        }

        // Éxito: cerrar este modal y abrir el de pago con la info reciente
        mostrarModalGenerar = false;
        facturaReciente = factura;
        modalSuccess = null;
        metodoPago = "";
        mostrarModalPagar = true;
    }

    private async Task PagarFactura()
    {
        if (string.IsNullOrEmpty(metodoPago))
        {
            modalError = "Selecciona un método de pago.";
            return;
        }
        if (facturaReciente == null) return;

        modalError = null;
        modalSuccess = null;
        guardando = true;

        var (ok, err) = await FacturaService.PagarFacturaAsync(facturaReciente.Id, new PagarFacturaRequest { MetodoPago = metodoPago });
        
        guardando = false;

        if (!ok)
        {
            modalError = err;
            return;
        }

        modalSuccess = "¡Pago registrado exitosamente! (TC-009 Pass)";
        if (facturaReciente != null) facturaReciente.Estado = "pagada";
    }
}
